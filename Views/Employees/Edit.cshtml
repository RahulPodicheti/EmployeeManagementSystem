@model EmployeeManagementSystem.ViewModels.EmployeeViewModel
<h2>Edit Employee</h2>

<form asp-action="Edit"
      method="post"
      enctype="multipart/form-data">

    <input type="hidden" asp-for="Employee.EmployeeId" />
    <input type="hidden" asp-for="Employee.PhotoPath" />

    <div class="mb-3">

        <label class="form-label">
            Current Photo
        </label>

        <br />

        @if (!string.IsNullOrEmpty(Model.Employee.PhotoPath))
        {
            <img src="@Model.Employee.PhotoPath"
                 width="120"
                 height="120"
                 class="rounded-circle border" />
        }
        else
        {
            <p>No Photo Available</p>
        }

    </div>

    <div class="mb-3">

        <label class="form-label">
            Change Photo
        </label>

        <input type="file"
               name="photo"
               accept=".jpg,.jpeg,.png,.gif,.webp"
               class="form-control" />

        <small class="text-success">
            ✓ Allowed: JPG, JPEG, PNG, GIF, WEBP
        </small>

        <br />

        <small class="text-danger">
            ✗ Not Allowed: PDF, DOC, DOCX, XLSX, ZIP
        </small>

    </div>

    <div class="mb-3">
        <label asp-for="Employee.FirstName"></label>
        <input asp-for="Employee.FirstName"
               class="form-control" />
    </div>

    <div class="mb-3">
        <label asp-for="Employee.LastName"></label>
        <input asp-for="Employee.LastName"
               class="form-control" />
    </div>

    <div class="mb-3">
        <label asp-for="Employee.Email"></label>
        <input asp-for="Employee.Email"
               class="form-control" />
    </div>

    <div class="mb-3">
        <label asp-for="Employee.PhoneNumber"></label>
        <input asp-for="Employee.PhoneNumber"
               class="form-control" />
    </div>

    <div class="mb-3">
        <label asp-for="Employee.Department"></label>
        <select asp-for="Employee.Department"
                asp-items="Model.Departments"
                class="form-select">

            <option value="">
                -- Select Department --
            </option>

        </select>
    </div>

    <div class="mb-3">
        <label asp-for="Employee.Salary"></label>
        <input asp-for="Employee.Salary"
               class="form-control" />
    </div>

    <div class="mb-3">
        <label asp-for="Employee.JoiningDate"></label>
        <input asp-for="Employee.JoiningDate"
               type="date"
               class="form-control" />
    </div>

    <div class="form-check mb-3">
        <input asp-for="Employee.IsActive"
               class="form-check-input" />

        <label asp-for="Employee.IsActive"
               class="form-check-label">
        </label>
    </div>

    <button type="submit"
            class="btn btn-success">
        Update
    </button>

    <a asp-action="Index"
       class="btn btn-secondary">
        Back
    </a>

</form>