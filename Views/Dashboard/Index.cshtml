@model EmployeeManagementSystem.Models.DashboardStats

<h2 class="mb-4">Dashboard</h2>

<div class="row">

    <div class="col-md-4">
        <div class="card text-center shadow">
            <div class="card-body">
                <h3>@Model.TotalEmployees</h3>
                <p>Total Employees</p>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card text-center shadow">
            <div class="card-body">
                <h3>@Model.ActiveEmployees</h3>
                <p>Active Employees</p>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card text-center shadow">
            <div class="card-body">
                <h3>@Model.InactiveEmployees</h3>
                <p>Inactive Employees</p>
            </div>
        </div>
    </div>

</div>